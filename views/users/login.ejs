<% layout("layouts/boilerplate") %>

<style>
  .auth-page {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    background: #f8f9fb;
    padding: 40px 16px;
  }
  .auth-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    overflow: hidden;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
  }
  .auth-header {
    background: linear-gradient(135deg, #1a1a2e, #2d2d5e);
    padding: 32px 36px 28px;
    text-align: center;
  }
  .auth-header .brand { font-size: 22px; font-weight: 900; color: #fff; letter-spacing: -0.5px; }
  .auth-header .brand span { color: #6c8ebf; }
  .auth-header h2 { font-size: 18px; font-weight: 700; color: #fff; margin: 12px 0 4px; }
  .auth-header p  { font-size: 13px; color: rgba(255,255,255,0.55); margin: 0; }
  .auth-body { padding: 32px 36px; }
  .form-label { font-size: 13px; font-weight: 600; color: #444; margin-bottom: 5px; }
  .input-wrap { position: relative; }
  .input-wrap i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #bbb; font-size: 15px; }
  .input-wrap .form-control { padding-left: 36px; }
  .form-control {
    border: 1px solid #e5e7eb; border-radius: 9px;
    padding: 11px 12px; font-size: 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-control:focus { border-color: #1a1a2e; box-shadow: 0 0 0 3px rgba(26,26,46,0.08); outline: none; }
  .btn-auth {
    width: 100%; background: #1a1a2e; color: #fff;
    border: none; border-radius: 9px; padding: 12px;
    font-size: 15px; font-weight: 700; cursor: pointer;
    transition: background 0.2s; margin-top: 4px;
  }
  .btn-auth:hover { background: #2d2d5e; }
  .auth-footer-text { text-align: center; font-size: 13px; color: #888; margin-top: 20px; }
  .auth-footer-text a { color: #1a1a2e; font-weight: 600; text-decoration: none; }
  .auth-footer-text a:hover { text-decoration: underline; }
</style>

<div class="auth-page">
  <div class="auth-card">

    <div class="auth-header">
      <div class="brand">Hire<span>Hub</span></div>
      <h2>Welcome back</h2>
      <p>Sign in to your account to continue</p>
    </div>

    <div class="auth-body">
      <form action="/login" method="POST" class="needs-validation" novalidate>

        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <div class="input-wrap">
            <i class="bi bi-person"></i>
            <input id="username" name="username" type="text" class="form-control" placeholder="Enter your username" required />
          </div>
          <div class="invalid-feedback">Username is required.</div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label">Password</label>
          <div class="input-wrap">
            <i class="bi bi-lock"></i>
            <input id="password" name="password" type="password" class="form-control" placeholder="Enter your password" required />
          </div>
          <div class="invalid-feedback">Password is required.</div>
        </div>

        <button type="submit" class="btn-auth">
          <i class="bi bi-box-arrow-in-right me-2"></i>Login
        </button>

      </form>

      <p class="auth-footer-text">
        Don't have an account? <a href="/signup">Sign up free</a>
      </p>
    </div>

  </div>
</div>

<script>
  (function () {
    'use strict'
    document.querySelectorAll('.needs-validation').forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
