<% layout("layouts/boilerplate") %>

<style>
  .auth-page {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    background: #f8f9fb;
    padding: 40px 16px;
  }
  .auth-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    overflow: hidden;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
  }
  .auth-header {
    background: linear-gradient(135deg, #1a1a2e, #2d2d5e);
    padding: 32px 36px 28px;
    text-align: center;
  }
  .auth-header { background: linear-gradient(140deg, #0f172a 0%, #1a1a2e 50%, #2d2d5e 100%); position: relative; overflow: hidden; }
  .auth-header::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 20px 20px; }
  .auth-header .inner-h { position: relative; z-index: 1; }
  .auth-header .brand { font-size: 22px; font-weight: 900; color: #fff; letter-spacing: -0.05em; font-family: 'Inter', sans-serif; }
  .auth-header .brand span { color: #a78bfa; }
  .auth-header h2 { font-size: 19px; font-weight: 800; color: #fff; margin: 12px 0 4px; letter-spacing: -0.03em; }
  .auth-header p  { font-size: 13px; color: rgba(255,255,255,0.5); margin: 0; }
  .auth-body { padding: 32px 36px; }
  .form-label { font-size: 13px; font-weight: 600; color: #444; margin-bottom: 5px; font-family: 'Inter', sans-serif; }
  .input-wrap { position: relative; }
  .input-wrap i.icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #bbb; font-size: 15px; }
  .input-wrap .form-control { padding-left: 36px; }
  .form-control {
    border: 1.5px solid #e2e8f0; border-radius: 9px;
    padding: 11px 13px; font-size: 14px; font-family: 'Inter', sans-serif;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-control:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.12); outline: none; }

  /* Role selector */
  .role-selector { display: flex; gap: 12px; margin-top: 2px; }
  .role-option { flex: 1; }
  .role-option input[type="radio"] { display: none; }
  .role-option label {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    border: 2px solid #e2e8f0; border-radius: 10px;
    padding: 14px 10px; cursor: pointer;
    transition: all 0.2s; text-align: center; width: 100%;
    font-size: 13px; font-weight: 600; color: #94a3b8;
    font-family: 'Inter', sans-serif;
  }
  .role-option label i { font-size: 22px; color: #cbd5e1; transition: color 0.2s; }
  .role-option input[type="radio"]:checked + label {
    border-color: #4f46e5; background: #eef2ff; color: #4f46e5;
  }
  .role-option input[type="radio"]:checked + label i { color: #4f46e5; }
  .role-option label:hover { border-color: #a5b4fc; color: #6366f1; }

  .btn-auth {
    width: 100%; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff;
    border: none; border-radius: 10px; padding: 13px;
    font-size: 15px; font-weight: 700; cursor: pointer;
    transition: opacity 0.2s, transform 0.2s; margin-top: 4px;
    font-family: 'Inter', sans-serif;
    box-shadow: 0 4px 16px rgba(124,58,237,0.35);
  }
  .btn-auth:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 22px rgba(124,58,237,0.45); }
  .auth-footer-text { text-align: center; font-size: 13px; color: #94a3b8; margin-top: 20px; font-family: 'Inter', sans-serif; }
  .auth-footer-text a { color: #4f46e5; font-weight: 700; text-decoration: none; }
  .auth-footer-text a:hover { text-decoration: underline; }

  /* ── Mobile ── */
  @media (max-width: 575.98px) {
    .auth-page   { padding: 20px 12px; align-items: flex-start; padding-top: 28px; }
    .auth-card   { max-width: 100%; }
    .auth-header { padding: 24px 20px 20px; }
    .auth-header h2 { font-size: 17px; }
    .auth-body   { padding: 22px 20px; }
    .btn-auth    { padding: 12px; font-size: 14px; }
    .role-selector { gap: 10px; }
    .role-option label { padding: 12px 8px; font-size: 12.5px; }
    .role-option label i { font-size: 20px; }
  }
</style>

<div class="auth-page">
  <div class="auth-card">

    <div class="auth-header" style="padding:32px 36px 28px;text-align:center;">
      <div class="inner-h">
        <div class="brand">Hire<span>Hub</span></div>
        <h2>Create your account</h2>
        <p>Join thousands finding jobs on HireHub</p>
      </div>
    </div>

    <div class="auth-body">
      <form action="/signup" method="POST" class="needs-validation" novalidate>

        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <div class="input-wrap">
            <i class="bi bi-person icon"></i>
            <input id="username" name="username" type="text" class="form-control" placeholder="Choose a username" required />
          </div>
          <div class="invalid-feedback">Username is required.</div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <div class="input-wrap">
            <i class="bi bi-envelope icon"></i>
            <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required />
          </div>
          <div class="invalid-feedback">Valid email is required.</div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label">Password</label>
          <div class="input-wrap">
            <i class="bi bi-lock icon"></i>
            <input id="password" name="password" type="password" class="form-control" placeholder="Create a password" required />
          </div>
          <div class="invalid-feedback">Password is required.</div>
        </div>

        <div class="mb-4">
          <label class="form-label">I am a...</label>
          <div class="role-selector">
            <div class="role-option">
              <input type="radio" id="candidate" name="role" value="candidate" checked />
              <label for="candidate">
                <i class="bi bi-person-badge"></i>
                Candidate
              </label>
            </div>
            <div class="role-option">
              <input type="radio" id="employer" name="role" value="employer" />
              <label for="employer">
                <i class="bi bi-building"></i>
                Employer
              </label>
            </div>
          </div>
        </div>

        <button type="submit" class="btn-auth">
          <i class="bi bi-person-plus me-2"></i>Create Account
        </button>

      </form>

      <p class="auth-footer-text">
        Already have an account? <a href="/login">Login</a>
      </p>
    </div>

  </div>
</div>

<script>
  (function () {
    'use strict'
    document.querySelectorAll('.needs-validation').forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
