<% layout("/layouts/boilerplate") %>

<style>
  .error-page {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8f9fb;
    padding: 40px 16px;
  }
  .error-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    padding: 52px 44px;
    text-align: center;
    max-width: 520px;
    width: 100%;
  }
  .error-icon-wrap {
    width: 80px; height: 80px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 36px; margin: 0 auto 24px;
  }
  .error-code {
    font-size: 72px; font-weight: 900; line-height: 1;
    margin-bottom: 8px; letter-spacing: -2px;
  }
  .error-title {
    font-size: 20px; font-weight: 700; color: #1a1a2e;
    margin-bottom: 10px;
  }
  .error-message {
    font-size: 15px; color: #888; line-height: 1.6;
    margin-bottom: 32px;
  }
  .error-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-home {
    background: #1a1a2e; color: #fff; border-radius: 9px;
    padding: 11px 24px; font-size: 14px; font-weight: 700;
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    transition: background 0.2s;
  }
  .btn-home:hover { background: #2d2d5e; color: #fff; }
  .btn-back {
    background: #fff; color: #555; border: 1px solid #e0e0e0;
    border-radius: 9px; padding: 11px 24px; font-size: 14px; font-weight: 600;
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    transition: all 0.2s; cursor: pointer;
  }
  .btn-back:hover { border-color: #1a1a2e; color: #1a1a2e; }
</style>

<div class="error-page">
  <div class="error-card">

    <% if (statusCode === 404) { %>
      <div class="error-icon-wrap" style="background:#e8f0fe;color:#3b6fd4;">
        <i class="bi bi-search"></i>
      </div>
      <div class="error-code" style="color:#3b6fd4;">404</div>
      <div class="error-title">Page Not Found</div>
      <p class="error-message">
        The page you're looking for doesn't exist or may have been moved.<br/>
        <%= message %>
      </p>

    <% } else if (statusCode === 403) { %>
      <div class="error-icon-wrap" style="background:#fff3e0;color:#e65100;">
        <i class="bi bi-shield-lock"></i>
      </div>
      <div class="error-code" style="color:#e65100;">403</div>
      <div class="error-title">Access Denied</div>
      <p class="error-message">
        You don't have permission to access this page.<br/>
        <%= message %>
      </p>

    <% } else if (statusCode === 401) { %>
      <div class="error-icon-wrap" style="background:#fff3e0;color:#e65100;">
        <i class="bi bi-lock"></i>
      </div>
      <div class="error-code" style="color:#e65100;">401</div>
      <div class="error-title">Unauthorized</div>
      <p class="error-message">
        You need to be logged in to access this page.<br/>
        <%= message %>
      </p>

    <% } else { %>
      <div class="error-icon-wrap" style="background:#fdecea;color:#c62828;">
        <i class="bi bi-exclamation-triangle"></i>
      </div>
      <div class="error-code" style="color:#c62828;"><%= statusCode %></div>
      <div class="error-title">Something Went Wrong</div>
      <p class="error-message">
        An unexpected error occurred on our end. Please try again.<br/>
        <%= message %>
      </p>
    <% } %>

    <div class="error-actions">
      <a href="/home" class="btn-home"><i class="bi bi-house"></i> Go Home</a>
      <button onclick="history.back()" class="btn-back"><i class="bi bi-arrow-left"></i> Go Back</button>
    </div>

  </div>
</div>
