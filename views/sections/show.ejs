<% layout("layouts/boilerplate") %>

<style>
  .show-wrapper { max-width: 860px; margin: 0 auto; padding: 36px 16px; }
  .back-link { font-size: 13px; color: #888; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 20px; }
  .back-link:hover { color: #333; }

  .job-header {
    background: #fff;
    border-radius: 14px;
    padding: 28px 32px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    margin-bottom: 20px;
  }
  .company-logo {
    width: 56px; height: 56px; border-radius: 14px;
    background: #1a1a2e; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 800; flex-shrink: 0;
  }
  .job-title { font-size: 24px; font-weight: 800; color: #1a1a2e; margin: 0 0 4px; }
  .job-company { font-size: 15px; color: #555; margin: 0; font-weight: 500; }
  .tag { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 600; }
  .tag-blue   { background: #e8f0fe; color: #3b6fd4; }
  .tag-green  { background: #e6f4ea; color: #2e7d32; }
  .tag-orange { background: #fff3e0; color: #e65100; }
  .tag-purple { background: #f3e8fd; color: #7b2da0; }
  .tag-teal   { background: #e0f2f1; color: #00695c; }
  .meta-row { display: flex; flex-wrap: wrap; gap: 20px; margin: 16px 0; }
  .meta-item { display: flex; align-items: center; gap: 6px; font-size: 14px; color: #666; }
  .meta-item i { color: #aaa; }
  .salary-highlight { font-size: 20px; font-weight: 800; color: #2e7d32; }

  .section-card {
    background: #fff;
    border-radius: 14px;
    padding: 24px 32px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    margin-bottom: 20px;
  }
  .section-card h5 { font-size: 15px; font-weight: 700; color: #1a1a2e; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid #f0f0f0; }
  .description-text { font-size: 14px; color: #555; line-height: 1.8; white-space: pre-wrap; margin: 0; }
  .skill-tag { display: inline-block; padding: 5px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; background: #f0f2f5; color: #444; margin: 4px 4px 4px 0; }

  .poster-info { display: flex; align-items: center; gap: 12px; }
  .poster-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: #1a1a2e; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 15px;
  }
  .poster-name { font-weight: 600; font-size: 14px; color: #1a1a2e; }
  .poster-label { font-size: 12px; color: #aaa; }

  .apply-section {
    background: linear-gradient(135deg, #1a1a2e, #2d2d5e);
    border-radius: 14px;
    padding: 28px 32px;
    text-align: center;
    color: #fff;
    box-shadow: 0 4px 16px rgba(26,26,46,0.2);
  }
  .apply-section h5 { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .apply-section p { color: rgba(255,255,255,0.65); font-size: 14px; margin-bottom: 20px; }
  .btn-apply { background: #fff; color: #1a1a2e; border: none; border-radius: 10px; padding: 12px 32px; font-size: 15px; font-weight: 700; text-decoration: none; display: inline-block; transition: all 0.2s; }
  .btn-apply:hover { background: #f0f2f5; color: #1a1a2e; }
  .btn-back { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #fff; border-radius: 10px; padding: 12px 24px; font-size: 14px; font-weight: 500; text-decoration: none; display: inline-block; margin-left: 12px; transition: all 0.2s; }
  .btn-back:hover { background: rgba(255,255,255,0.1); color: #fff; }
</style>

<div class="show-wrapper">

  <a href="/jobs" class="back-link"><i class="bi bi-arrow-left"></i> Back to Jobs</a>

  <!-- Header Card -->
  <div class="job-header">
    <div style="display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;">
      <div class="company-logo"><%= job.company[0].toUpperCase() %></div>
      <div style="flex:1;">
        <h1 class="job-title"><%= job.title %></h1>
        <p class="job-company"><%= job.company %></p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;">
          <% if (job.jobType) { %><span class="tag tag-blue"><%= job.jobType %></span><% } %>
          <% if (job.workMode) { %><span class="tag tag-green"><%= job.workMode %></span><% } %>
          <% if (job.experienceLevel) { %><span class="tag tag-orange"><%= job.experienceLevel %></span><% } %>
        </div>
      </div>
      <% if (job.salary) { %>
        <div class="salary-highlight">$<%= job.salary.toLocaleString() %> CAD</div>
      <% } %>
    </div>

    <div class="meta-row">
      <div class="meta-item"><i class="bi bi-geo-alt"></i> <%= job.location %></div>
      <% if (job.postedAt) { %>
        <div class="meta-item"><i class="bi bi-clock"></i> Posted <%= new Date(job.postedAt).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) %></div>
      <% } %>
      <div class="meta-item">
        <div class="poster-info">
          <div class="poster-avatar"><%= job.owner.username[0].toUpperCase() %></div>
          <div>
            <div class="poster-label">Posted by</div>
            <div class="poster-name"><%= job.owner.username %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Description -->
  <div class="section-card">
    <h5><i class="bi bi-file-text me-2"></i>Job Description</h5>
    <p class="description-text"><%= job.description %></p>
  </div>

  <!-- Skills -->
  <% if (job.skills && job.skills.length > 0) { %>
    <div class="section-card">
      <h5><i class="bi bi-tools me-2"></i>Required Skills</h5>
      <% job.skills.forEach(skill => { %>
        <span class="skill-tag"><%= skill %></span>
      <% }) %>
    </div>
  <% } %>

  <!-- Apply Section -->
  <div class="apply-section">
    <h5>Interested in this role?</h5>
    <p>Submit your application and we'll notify you about the result via email.</p>
    <% if (!userAlreadyApplied) { %>
      <a href="/applications/<%= job._id %>/apply" class="btn-apply">Apply Now</a>
      <a href="/jobs" class="btn-back">Browse More</a>
    <% } else { %>
      <button class="btn-apply" disabled style="opacity:0.6;cursor:not-allowed;">Already Applied</button>
      <a href="/jobs" class="btn-back">Browse More</a>
    <% } %>
  </div>

</div>
