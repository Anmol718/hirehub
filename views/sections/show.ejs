<% layout("layouts/boilerplate") %>

<style>
  .show-page { max-width: 880px; margin: 0 auto; padding: 36px 16px 64px; }

  .back-link {
    font-size: 13px; font-weight: 600; color: var(--hh-text-muted);
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    margin-bottom: 24px; transition: color 0.18s;
    padding: 6px 12px; border-radius: 8px; border: 1px solid var(--hh-border);
    background: var(--hh-surface);
  }
  .back-link:hover { color: var(--hh-brand); border-color: var(--hh-brand); background: var(--hh-border-light); }

  /* Header card */
  .job-header-card {
    background: var(--hh-surface); border-radius: 16px;
    box-shadow: var(--shadow-md); border: 1px solid var(--hh-border-light);
    overflow: hidden; margin-bottom: 20px;
  }
  .job-header-banner {
    height: 8px;
    background: linear-gradient(90deg, var(--hh-accent) 0%, var(--hh-purple) 100%);
  }
  .job-header-body { padding: 30px 32px; }

  .jh-logo {
    width: 60px; height: 60px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; font-weight: 900; color: #fff; flex-shrink: 0;
    background: linear-gradient(135deg, var(--hh-brand), var(--hh-brand-light));
    box-shadow: 0 4px 16px rgba(26,26,46,0.25);
  }
  .jh-title   { font-size: 26px; font-weight: 900; color: var(--hh-text); margin: 0 0 4px; letter-spacing: -0.03em; }
  .jh-company { font-size: 15px; color: var(--hh-text-2); margin: 0; font-weight: 500; }

  .salary-pill {
    background: linear-gradient(135deg, #d1fae5, #a7f3d0);
    color: var(--hh-green); font-size: 17px; font-weight: 800;
    padding: 8px 16px; border-radius: 10px; border: 1px solid #6ee7b7;
    white-space: nowrap;
  }

  .meta-row { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px; padding-top: 18px; border-top: 1px solid var(--hh-border-light); }
  .meta-item { display: flex; align-items: center; gap: 7px; font-size: 14px; color: var(--hh-text-2); }
  .meta-item i { color: var(--hh-text-muted); font-size: 15px; }

  .poster-chip {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--hh-border-light); border-radius: 9999px;
    padding: 5px 12px 5px 5px; font-size: 13px; font-weight: 500; color: var(--hh-text);
    border: 1px solid var(--hh-border);
  }
  .poster-av {
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--hh-brand), var(--hh-accent));
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
  }

  /* Section cards */
  .info-card {
    background: var(--hh-surface); border-radius: 14px;
    padding: 26px 30px; box-shadow: var(--shadow-sm);
    border: 1px solid var(--hh-border-light); margin-bottom: 18px;
  }
  .info-card-title {
    font-size: 14px; font-weight: 700; color: var(--hh-text);
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--hh-border-light);
    display: flex; align-items: center; gap: 8px;
  }
  .info-card-title i { color: var(--hh-accent); }

  .desc-text {
    font-size: 14.5px; color: var(--hh-text-2); line-height: 1.85;
    white-space: pre-wrap; margin: 0;
  }

  .skill-chip {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500;
    background: var(--hh-accent-bg); color: var(--hh-accent);
    border: 1px solid rgba(79,70,229,0.15);
    margin: 4px 4px 4px 0;
    transition: all 0.18s;
  }
  .skill-chip:hover { background: var(--hh-accent); color: #fff; transform: translateY(-1px); }

  /* Apply CTA */
  .apply-cta {
    background: linear-gradient(135deg, #0f172a 0%, var(--hh-brand) 40%, var(--hh-brand-mid) 100%);
    border-radius: 16px; padding: 36px 36px 34px;
    text-align: center; color: #fff;
    box-shadow: 0 8px 32px rgba(26,26,46,0.3);
    position: relative; overflow: hidden;
  }
  .apply-cta::before {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .apply-cta-inner { position: relative; z-index: 1; }
  .apply-cta h5 { font-size: 20px; font-weight: 800; margin-bottom: 8px; }
  .apply-cta p  { color: rgba(255,255,255,0.6); font-size: 14px; margin-bottom: 24px; }

  .btn-apply-now {
    background: #fff; color: var(--hh-brand); border: none;
    border-radius: 10px; padding: 13px 32px; font-size: 15px; font-weight: 800;
    text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s var(--ease-bounce);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    font-family: 'Inter', sans-serif;
  }
  .btn-apply-now:hover { background: #f1f5f9; color: var(--hh-brand); transform: translateY(-3px) scale(1.02); box-shadow: 0 8px 30px rgba(0,0,0,0.28); }

  .btn-browse {
    background: rgba(255,255,255,0.1); color: #fff;
    border: 1.5px solid rgba(255,255,255,0.25); border-radius: 10px;
    padding: 12px 24px; font-size: 14px; font-weight: 500;
    text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
    margin-left: 12px; transition: all 0.2s;
    font-family: 'Inter', sans-serif;
  }
  .btn-browse:hover { background: rgba(255,255,255,0.2); color: #fff; }

  .applied-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(4,120,87,0.2); border: 1px solid rgba(16,185,129,0.3);
    color: #6ee7b7; border-radius: 10px; padding: 12px 24px;
    font-size: 15px; font-weight: 700;
  }
</style>

<div class="show-page">

  <a href="/jobs" class="back-link"><i class="bi bi-arrow-left"></i> Back to Jobs</a>

  <!-- Header Card -->
  <div class="job-header-card reveal">
    <%
      const bannerGrad =
        job.jobType === 'Full-Time'  ? 'linear-gradient(90deg,#2563eb,#4f46e5)' :
        job.jobType === 'Part-Time'  ? 'linear-gradient(90deg,#7c3aed,#a855f7)' :
        job.jobType === 'Contract'   ? 'linear-gradient(90deg,#d97706,#f59e0b)' :
        job.jobType === 'Internship' ? 'linear-gradient(90deg,#059669,#10b981)' :
        'linear-gradient(90deg,#4f46e5,#7c3aed)';
    %>
    <div class="job-header-banner" style="background:<%= bannerGrad %>;"></div>
    <div class="job-header-body">
      <div style="display:flex;align-items:flex-start;gap:18px;flex-wrap:wrap;">
        <div class="jh-logo"><%= job.company[0].toUpperCase() %></div>
        <div style="flex:1;min-width:0;">
          <h1 class="jh-title"><%= job.title %></h1>
          <p class="jh-company"><%= job.company %></p>
          <div style="display:flex;flex-wrap:wrap;gap:7px;margin-top:12px;">
            <% if (job.jobType) { %><span class="tag <%= job.jobType === 'Full-Time' ? 'tag-blue' : job.jobType === 'Part-Time' ? 'tag-purple' : job.jobType === 'Contract' ? 'tag-orange' : 'tag-green' %>"><%= job.jobType %></span><% } %>
            <% if (job.workMode) { %><span class="tag <%= job.workMode === 'Remote' ? 'tag-sky' : job.workMode === 'Hybrid' ? 'tag-purple' : 'tag-green' %>"><%= job.workMode %></span><% } %>
            <% if (job.experienceLevel) { %><span class="tag tag-accent"><%= job.experienceLevel %> Level</span><% } %>
          </div>
        </div>
        <% if (job.salary) { %>
          <div class="salary-pill">$<%= job.salary.toLocaleString() %> CAD</div>
        <% } %>
      </div>

      <div class="meta-row">
        <div class="meta-item"><i class="bi bi-geo-alt-fill"></i> <%= job.location %></div>
        <% if (job.postedAt) { %>
          <div class="meta-item"><i class="bi bi-calendar3"></i> Posted <%= new Date(job.postedAt).toLocaleDateString('en-CA', { day:'numeric', month:'long', year:'numeric' }) %></div>
        <% } %>
        <div class="meta-item">
          <div class="poster-chip">
            <div class="poster-av"><%= job.owner.username[0].toUpperCase() %></div>
            <span><%= job.owner.username %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Description -->
  <div class="info-card reveal reveal-d1">
    <div class="info-card-title"><i class="bi bi-file-earmark-text-fill"></i>Job Description</div>
    <p class="desc-text"><%= job.description %></p>
  </div>

  <!-- Skills -->
  <% if (job.skills && job.skills.length > 0) { %>
    <div class="info-card reveal reveal-d2">
      <div class="info-card-title"><i class="bi bi-tools"></i>Required Skills</div>
      <div>
        <% job.skills.forEach(skill => { %>
          <span class="skill-chip"><i class="bi bi-check2"></i><%= skill %></span>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Apply CTA -->
  <div class="apply-cta reveal reveal-d3">
    <div class="apply-cta-inner">
      <h5>Ready to Apply?</h5>
      <p>Submit your resume and we'll notify you immediately when the employer responds.</p>
      <% if (!userAlreadyApplied) { %>
        <a href="/applications/<%= job._id %>/apply" class="btn-apply-now">
          <i class="bi bi-send-fill"></i>Apply Now
        </a>
        <a href="/jobs" class="btn-browse"><i class="bi bi-briefcase"></i>Browse More</a>
      <% } else { %>
        <div class="applied-badge"><i class="bi bi-check-circle-fill"></i>Application Submitted</div>
        <a href="/jobs" class="btn-browse" style="margin-top:12px;display:inline-flex;"><i class="bi bi-briefcase"></i>Browse More Jobs</a>
      <% } %>
    </div>
  </div>

</div>
