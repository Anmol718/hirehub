<!-- ═══════════════════════════════════════ FEATURED JOBS -->
<% if (featuredJobs && featuredJobs.length > 0) { %>
<section class="page-section" style="background:var(--hh-bg);">
  <div class="container">
    <div class="reveal">
      <div class="section-overline">Opportunities</div>
      <div class="section-title">Featured Jobs</div>
      <div class="section-sub">Handpicked listings to kickstart your career</div>
    </div>

    <div class="row g-3">
      <% featuredJobs.forEach((job, i) => {
        const coColors = ['linear-gradient(135deg,#1a1a2e,#4a5490)','linear-gradient(135deg,#1e40af,#4f46e5)','linear-gradient(135deg,#059669,#0d9488)'];
        const col = coColors[i % coColors.length];
      %>
        <div class="col-md-6 col-lg-4 reveal reveal-d<%= i+1 %>">
          <div class="feat-job-card">
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;">
              <div class="co-logo" style="background:<%= col %>;"><%= job.company[0].toUpperCase() %></div>
              <div style="flex:1;min-width:0;">
                <p class="fjc-title"><%= job.title %></p>
                <p class="fjc-company"><%= job.company %></p>
              </div>
            </div>

            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;">
              <% if (job.jobType)  { %><span class="tag tag-blue"><%= job.jobType %></span><% } %>
              <% if (job.workMode) { %><span class="tag tag-green"><%= job.workMode %></span><% } %>
              <% if (job.location) { %><span style="font-size:12px;color:var(--hh-text-muted);display:flex;align-items:center;gap:3px;"><i class="bi bi-geo-alt"></i><%= job.location %></span><% } %>
            </div>

            <p class="fjc-desc"><%= job.description.length > 95 ? job.description.substring(0, 92) + '…' : job.description %></p>

            <div class="fjc-footer">
              <% if (job.salary) { %>
                <span class="fjc-salary"><i class="bi bi-cash me-1"></i>$<%= job.salary.toLocaleString() %> CAD</span>
              <% } else { %><span></span><% } %>
              <a href="/jobs/<%= job._id %>" class="fjc-btn">View Job <i class="bi bi-arrow-right"></i></a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="text-center mt-5 reveal">
      <a href="/jobs" class="btn-hh-accent" style="font-size:15px;padding:13px 32px;">
        Browse All Jobs <i class="bi bi-arrow-right ms-1"></i>
      </a>
    </div>
  </div>
</section>
<% } %>

