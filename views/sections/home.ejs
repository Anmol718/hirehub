<% layout("layouts/boilerplate") %>

<style>
  /* ── Hero ── */
  .hero {
    background: linear-gradient(140deg, #0f172a 0%, #1a1a2e 45%, #2d2d5e 100%);
    color: #fff;
    padding: 88px 0 72px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .hero-blob {
    position: absolute; border-radius: 50%; filter: blur(72px); pointer-events: none;
  }
  .hero-blob-1 {
    width: 480px; height: 480px;
    background: rgba(79,70,229,0.18);
    top: -120px; right: -80px;
    animation: blobDrift1 14s ease-in-out infinite;
  }
  .hero-blob-2 {
    width: 320px; height: 320px;
    background: rgba(124,58,237,0.14);
    bottom: -60px; left: 80px;
    animation: blobDrift2 18s ease-in-out infinite;
  }
  .hero-blob-3 {
    width: 200px; height: 200px;
    background: rgba(37,99,235,0.12);
    top: 40%; left: 40%;
    animation: blobDrift1 22s ease-in-out infinite reverse;
  }

  .hero-content { position: relative; z-index: 2; }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 9999px; padding: 5px 14px;
    font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.8);
    margin-bottom: 24px; letter-spacing: 0.3px;
    animation: fadeIn 0.6s ease;
  }
  .hero-eyebrow .pulse-dot {
    width: 6px; height: 6px; background: #4ade80; border-radius: 50%;
    animation: pulseDot 2s ease-in-out infinite;
  }

  .hero h1 {
    font-size: clamp(38px, 5vw, 58px);
    font-weight: 900; line-height: 1.08;
    margin-bottom: 20px; letter-spacing: -0.04em;
    animation: fadeUp 0.7s ease 0.1s both;
  }
  .hero h1 .grad {
    background: linear-gradient(135deg, #818cf8 0%, #a78bfa 50%, #c4b5fd 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 17px; color: rgba(255,255,255,0.62);
    margin-bottom: 36px; max-width: 500px; line-height: 1.7;
    animation: fadeUp 0.7s ease 0.2s both;
  }

  .hero-search {
    background: #fff; border-radius: 14px;
    padding: 6px 6px 6px 18px;
    display: flex; gap: 6px; align-items: center;
    max-width: 580px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.25), 0 2px 8px rgba(0,0,0,0.1);
    animation: fadeUp 0.7s ease 0.3s both;
  }
  .hero-search .hs-icon { color: #94a3b8; flex-shrink: 0; }
  .hero-search input {
    border: none; outline: none; font-size: 14.5px;
    flex: 1; color: #0f172a; background: transparent;
    font-family: 'Inter', sans-serif; padding: 6px 0;
  }
  .hero-search input::placeholder { color: #94a3b8; }
  .hero-search .hs-divider { width: 1px; height: 22px; background: #e2e8f0; flex-shrink: 0; }
  .hero-search button {
    background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none;
    border-radius: 10px; padding: 12px 22px;
    font-size: 14px; font-weight: 700; cursor: pointer; white-space: nowrap;
    transition: opacity 0.2s, transform 0.2s; display: flex; align-items: center; gap: 6px;
    font-family: 'Inter', sans-serif;
  }
  .hero-search button:hover { opacity: 0.9; transform: translateY(-1px); }

  .hero-tags {
    margin-top: 20px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center;
    animation: fadeUp 0.7s ease 0.4s both;
  }
  .hero-tags .lbl { font-size: 12px; color: rgba(255,255,255,0.45); }
  .hero-tag {
    background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.72);
    border: 1px solid rgba(255,255,255,0.14); border-radius: 9999px;
    padding: 4px 13px; font-size: 12.5px; font-weight: 500; text-decoration: none;
    transition: all 0.2s; font-family: 'Inter', sans-serif;
  }
  .hero-tag:hover { background: rgba(255,255,255,0.18); color: #fff; border-color: rgba(255,255,255,0.3); }

  /* Floating cards on the right */
  .hero-cards { position: relative; }
  .hero-card {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 16px; padding: 18px 22px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .hero-card-1 {
    animation: float 5s ease-in-out infinite;
    animation-delay: 0s;
  }
  .hero-card-2 {
    animation: float-delayed 6s ease-in-out infinite;
    animation-delay: -2s;
    margin-top: 16px;
    margin-left: 24px;
  }
  .hc-logo {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 800; color: #fff; flex-shrink: 0;
  }
  .hc-title { font-weight: 700; font-size: 14px; color: #fff; }
  .hc-sub   { font-size: 12px; color: rgba(255,255,255,0.55); }
  .hc-badge {
    padding: 3px 10px; border-radius: 9999px; font-size: 11px; font-weight: 700;
    white-space: nowrap;
  }

  .hero-social-proof {
    margin-top: 20px;
    display: flex; align-items: center; gap: 10px;
    animation: fadeUp 0.7s ease 0.5s both;
  }
  .avatar-stack { display: flex; }
  .avatar-stack .av {
    width: 30px; height: 30px; border-radius: 50%;
    border: 2px solid #1a1a2e;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff;
    margin-left: -8px;
  }
  .avatar-stack .av:first-child { margin-left: 0; }
  .hero-social-proof .sp-text { font-size: 13px; color: rgba(255,255,255,0.55); }
  .hero-social-proof .sp-text strong { color: rgba(255,255,255,0.85); }

  /* ── Stats ── */
  .stats-section {
    background: var(--hh-surface);
    border-bottom: 1px solid var(--hh-border-light);
    padding: 36px 0;
  }
  .stat-item { text-align: center; padding: 0 24px; }
  .stat-num {
    font-size: 36px; font-weight: 900; color: var(--hh-brand);
    line-height: 1; letter-spacing: -0.04em;
    font-family: 'Inter', sans-serif;
  }
  .stat-lbl { font-size: 13px; color: var(--hh-text-muted); margin-top: 6px; font-weight: 500; }
  .stat-sep { width: 1px; background: var(--hh-border); align-self: stretch; }

  /* ── Trusted strip ── */
  .trust-section {
    background: var(--hh-bg);
    border-bottom: 1px solid var(--hh-border-light);
    padding: 28px 0;
    overflow: hidden;
  }
  .trust-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.2px; color: var(--hh-text-muted); text-align: center; margin-bottom: 18px; }
  .trust-ticker-wrap { overflow: hidden; }
  .trust-ticker {
    display: flex; gap: 48px; width: max-content;
    animation: ticker 28s linear infinite;
  }
  .trust-ticker:hover { animation-play-state: paused; }
  .trust-name {
    font-size: 14px; font-weight: 700; color: var(--hh-text-muted);
    white-space: nowrap; letter-spacing: -0.01em;
    opacity: 0.7; transition: opacity 0.2s;
  }
  .trust-name:hover { opacity: 1; color: var(--hh-brand); }

  /* ── Section layout ── */
  .page-section { padding: 72px 0; }
  .section-overline {
    font-size: 11.5px; font-weight: 700; letter-spacing: 1.6px;
    text-transform: uppercase; color: var(--hh-accent); margin-bottom: 10px;
  }
  .section-title { font-size: 30px; font-weight: 800; color: var(--hh-text); margin-bottom: 8px; letter-spacing: -0.03em; }
  .section-sub   { font-size: 15px; color: var(--hh-text-muted); margin-bottom: 44px; }

  /* ── Featured Job Cards ── */
  .feat-job-card {
    background: var(--hh-surface);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid var(--hh-border-light);
    box-shadow: var(--shadow-sm);
    height: 100%; display: flex; flex-direction: column;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s;
    position: relative; overflow: hidden;
  }
  .feat-job-card::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--hh-accent), var(--hh-purple));
    opacity: 0; transition: opacity 0.25s;
  }
  .feat-job-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-xl);
    border-color: rgba(79,70,229,0.15);
  }
  .feat-job-card:hover::after { opacity: 1; }

  .co-logo {
    width: 46px; height: 46px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 800; color: #fff; flex-shrink: 0;
    background: linear-gradient(135deg, var(--hh-brand), var(--hh-brand-light));
  }
  .fjc-title   { font-size: 16px; font-weight: 700; color: var(--hh-text); margin: 0 0 2px; }
  .fjc-company { font-size: 13px; color: var(--hh-text-muted); margin: 0; }
  .fjc-desc { font-size: 13px; color: var(--hh-text-2); line-height: 1.65; flex: 1; margin: 14px 0 18px; }
  .fjc-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
  .fjc-salary { font-size: 14px; font-weight: 700; color: var(--hh-green); }
  .fjc-btn {
    background: var(--hh-brand); color: #fff; border-radius: 8px;
    padding: 7px 16px; font-size: 13px; font-weight: 700;
    text-decoration: none; transition: background 0.2s, transform 0.2s;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .fjc-btn:hover { background: var(--hh-brand-mid); color: #fff; transform: translateX(2px); }

  /* ── Feature Cards ── */
  .feat-card {
    background: var(--hh-surface); border-radius: 16px; padding: 30px 26px;
    box-shadow: var(--shadow-sm); text-align: center; height: 100%;
    border: 1px solid var(--hh-border-light);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s;
  }
  .feat-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-xl);
    border-color: rgba(79,70,229,0.12);
  }
  .feat-icon-wrap {
    width: 64px; height: 64px; border-radius: 18px;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; margin: 0 auto 20px;
    transition: transform 0.25s var(--ease-bounce);
  }
  .feat-card:hover .feat-icon-wrap { transform: scale(1.1) rotate(-4deg); }
  .feat-card h5 { font-size: 16px; font-weight: 700; color: var(--hh-text); margin-bottom: 10px; }
  .feat-card p  { font-size: 14px; color: var(--hh-text-2); line-height: 1.7; margin: 0; }

  /* ── Employer CTA banner ── */
  .employer-banner {
    background: linear-gradient(135deg, var(--hh-brand) 0%, #1e3a8a 50%, var(--hh-brand-mid) 100%);
    border-radius: 20px; padding: 44px 48px;
    display: flex; align-items: center; gap: 36px; flex-wrap: wrap;
    position: relative; overflow: hidden;
  }
  .employer-banner::before {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .employer-banner-icon {
    width: 68px; height: 68px; border-radius: 20px;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.18);
    display: flex; align-items: center; justify-content: center;
    font-size: 30px; color: #fff; flex-shrink: 0; position: relative;
  }
  .employer-banner h3 { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: 6px; position: relative; }
  .employer-banner p  { font-size: 14px; color: rgba(255,255,255,0.62); margin: 0; position: relative; }
  .btn-employer {
    background: #fff; color: var(--hh-brand); border-radius: 12px;
    padding: 13px 30px; font-size: 14px; font-weight: 800;
    text-decoration: none; white-space: nowrap; margin-left: auto;
    transition: all 0.2s var(--ease); position: relative;
    display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  .btn-employer:hover { background: #f1f5f9; color: var(--hh-brand); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.25); }

  /* ── Final CTA ── */
  .final-cta {
    background: linear-gradient(140deg, #0f172a 0%, var(--hh-brand) 40%, var(--hh-brand-mid) 100%);
    color: #fff; padding: 88px 0; text-align: center;
    position: relative; overflow: hidden;
  }
  .final-cta::before {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .final-cta-inner { position: relative; z-index: 1; }
  .final-cta h2 { font-size: clamp(28px, 4vw, 44px); font-weight: 900; margin-bottom: 14px; letter-spacing: -0.04em; }
  .final-cta p  { color: rgba(255,255,255,0.6); font-size: 17px; margin-bottom: 36px; max-width: 500px; margin-left: auto; margin-right: auto; }
  .btn-cta-white {
    background: #fff; color: var(--hh-brand); border-radius: 10px;
    padding: 14px 32px; font-size: 15px; font-weight: 800;
    text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s; margin: 0 8px 10px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .btn-cta-white:hover { background: #f1f5f9; color: var(--hh-brand); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.25); }
  .btn-cta-ghost {
    background: rgba(255,255,255,0.1); color: #fff;
    border: 1.5px solid rgba(255,255,255,0.25); border-radius: 10px;
    padding: 13px 32px; font-size: 15px; font-weight: 600;
    text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s; margin: 0 8px 10px;
  }
  .btn-cta-ghost:hover { background: rgba(255,255,255,0.2); color: #fff; transform: translateY(-2px); }

  /* ── Mobile responsive ── */
  @media (max-width: 767.98px) {
    .hero { padding: 48px 0 36px; }
    .hero h1 { letter-spacing: -0.03em; }
    .hero-sub { font-size: 15px; }
    .hero-eyebrow { margin-bottom: 16px; }

    /* Search bar: hide location field, make button full-width */
    .hero-search { flex-wrap: wrap; padding: 8px; gap: 6px; border-radius: 12px; }
    .hero-search .hs-divider { display: none; }
    .hero-search i.bi-geo-alt { display: none; }
    .hero-search input[name="location"] { display: none; }
    .hero-search input { flex: 1; min-width: 0; }
    .hero-search button { flex: 1 1 100%; justify-content: center; padding: 12px; border-radius: 8px; }

    .hero-tags { margin-top: 14px; gap: 6px; }
    .hero-social-proof { margin-top: 14px; flex-wrap: wrap; }

    /* Stats */
    .stats-section { padding: 20px 0; }
    .stat-num { font-size: 28px; }
    .stat-lbl { font-size: 12px; }

    /* Employer CTA */
    .employer-banner { padding: 24px 20px; flex-direction: column; align-items: flex-start; gap: 16px; }
    .employer-banner-icon { width: 52px; height: 52px; font-size: 22px; }
    .employer-banner h3 { font-size: 18px; }
    .btn-employer { margin-left: 0; width: 100%; justify-content: center; padding: 11px 20px; }

    /* Final CTA */
    .final-cta { padding: 52px 0; }
    .final-cta h2 { letter-spacing: -0.03em; }
    .final-cta p { font-size: 15px; }
    .btn-cta-white, .btn-cta-ghost { width: 100%; justify-content: center; margin: 0 0 10px; }

    /* Page sections */
    .page-section { padding: 48px 0; }
    .section-title { font-size: 24px; }
    .section-sub { font-size: 14px; margin-bottom: 28px; }

    /* Feature cards */
    .feat-icon-wrap { width: 52px; height: 52px; font-size: 22px; }
  }
</style>

<!-- ═══════════════════════════════════════ HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>
  <div class="hero-blob hero-blob-3"></div>

  <div class="container hero-content">
    <div class="row align-items-center g-5">

      <!-- Left -->
      <div class="col-lg-6">
        <div class="hero-eyebrow">
          <span class="pulse-dot"></span> Campus to Career Platform
        </div>

        <h1>Find Your Next<br/><span class="grad">Great Opportunity</span></h1>
        <p class="hero-sub">Connect with top employers, apply in minutes, and track every step — all from one powerful platform built for students.</p>

        <form class="hero-search" action="/jobs" method="GET">
          <i class="bi bi-search hs-icon"></i>
          <input type="text" name="search" placeholder="Job title, skill, or company…" autocomplete="off" />
          <div class="hs-divider"></div>
          <i class="bi bi-geo-alt hs-icon"></i>
          <input type="text" name="location" placeholder="Location" style="max-width:130px;" autocomplete="off" />
          <button type="submit"><i class="bi bi-arrow-right"></i>Search</button>
        </form>

        <div class="hero-tags">
          <span class="lbl">Trending:</span>
          <a href="/jobs?jobType=Internship" class="hero-tag">Internships</a>
          <a href="/jobs?jobType=Full-Time" class="hero-tag">Full-Time</a>
          <a href="/jobs?workMode=Remote" class="hero-tag">Remote</a>
          <a href="/jobs?jobType=Contract" class="hero-tag">Contract</a>
        </div>

        <div class="hero-social-proof">
          <div class="avatar-stack">
            <div class="av" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);">A</div>
            <div class="av" style="background:linear-gradient(135deg,#059669,#0d9488);">S</div>
            <div class="av" style="background:linear-gradient(135deg,#2563eb,#4f46e5);">M</div>
            <div class="av" style="background:linear-gradient(135deg,#d97706,#dc2626);">R</div>
          </div>
          <p class="sp-text mb-0"><strong>500+</strong> students hired this year</p>
        </div>
      </div>

      <!-- Right: Floating Job Cards -->
      <div class="col-lg-6 d-none d-lg-block">
        <div class="hero-cards ps-3">

          <div class="hero-card hero-card-1 mb-3">
            <div class="d-flex align-items-center gap-3">
              <div class="hc-logo" style="background:linear-gradient(135deg,#059669,#0d9488);">F</div>
              <div style="flex:1;min-width:0;">
                <div class="hc-title">Frontend Developer</div>
                <div class="hc-sub">FinanceCo · Toronto, ON</div>
              </div>
              <span class="hc-badge" style="background:#d1fae5;color:#059669;">Internship</span>
            </div>
            <div style="display:flex;justify-content:space-between;margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.1);">
              <span style="font-size:12px;color:rgba(255,255,255,0.5);display:flex;align-items:center;gap:4px;"><i class="bi bi-geo-alt"></i> Remote</span>
              <span style="font-size:13px;font-weight:700;color:#4ade80;">$55,000 CAD</span>
            </div>
          </div>

          <div class="hero-card hero-card-2">
            <div class="d-flex align-items-center gap-3">
              <div class="hc-logo" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);">T</div>
              <div style="flex:1;min-width:0;">
                <div class="hc-title">Data Analyst</div>
                <div class="hc-sub">TechCorp · Vancouver, BC</div>
              </div>
              <span class="hc-badge" style="background:#dbeafe;color:#2563eb;">Full-Time</span>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.1);">
              <div style="display:flex;align-items:center;gap:6px;">
                <div style="width:6px;height:6px;background:#4ade80;border-radius:50%;animation:pulseDot 2s infinite;"></div>
                <span style="font-size:12px;color:rgba(255,255,255,0.5);">Actively hiring</span>
              </div>
              <span style="font-size:13px;font-weight:700;color:#4ade80;">$72,000 CAD</span>
            </div>
          </div>

          <!-- Mini stat card -->
          <div style="display:flex;gap:10px;margin-top:12px;margin-left:48px;">
            <div style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:14px 18px;flex:1;">
              <div style="font-size:22px;font-weight:900;color:#fff;letter-spacing:-0.04em;"><%= featuredJobs.length %>+</div>
              <div style="font-size:12px;color:rgba(255,255,255,0.45);">Active listings</div>
            </div>
            <div style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:14px 18px;flex:1;">
              <div style="font-size:22px;font-weight:900;color:#4ade80;letter-spacing:-0.04em;">98%</div>
              <div style="font-size:12px;color:rgba(255,255,255,0.45);">Satisfaction</div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════ STATS -->
<section class="stats-section">
  <div class="container">
    <div class="row g-0 justify-content-center align-items-center text-center">
      <div class="col-6 col-md-3 reveal">
        <div class="stat-item">
          <div class="stat-num"><span data-count="1000" data-suffix="+">1000+</span></div>
          <div class="stat-lbl">Jobs Posted</div>
        </div>
      </div>
      <div class="col-6 col-md-3 reveal reveal-d1">
