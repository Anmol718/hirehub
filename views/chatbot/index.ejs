<% layout("layouts/boilerplate") %>

<style>
  .chat-page {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 64px);
    margin: 0 -12px;
    background: #f8f9fb;
  }

  /* Header */
  .chat-header {
    background: linear-gradient(135deg, #1a1a2e, #2d2d5e);
    color: #fff;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .chat-header-left { display: flex; align-items: center; gap: 10px; }
  .bot-avatar {
    width: 36px; height: 36px; border-radius: 10px;
    background: rgba(255,255,255,0.15);
    display: flex; align-items: center; justify-content: center;
    font-size: 17px;
  }
  .chat-header h5 { margin: 0; font-size: 15px; font-weight: 700; }
  .chat-header p  { margin: 0; font-size: 12px; color: rgba(255,255,255,0.6); }
  .btn-clear {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff; border-radius: 8px;
    padding: 6px 14px; font-size: 13px; font-weight: 500;
    cursor: pointer; transition: background 0.2s; text-decoration: none;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .btn-clear:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Messages */
  .messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-behavior: smooth;
  }

  /* Welcome state */
  .welcome-state {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    flex: 1; text-align: center; padding: 40px 20px;
  }
  .welcome-icon {
    width: 72px; height: 72px; border-radius: 20px;
    background: linear-gradient(135deg, #1a1a2e, #2d2d5e);
    display: flex; align-items: center; justify-content: center;
    font-size: 30px; color: #fff; margin-bottom: 20px;
    box-shadow: 0 8px 24px rgba(26,26,46,0.25);
  }
  .welcome-state h4 { font-size: 22px; font-weight: 800; color: #1a1a2e; margin-bottom: 8px; }
  .welcome-state p  { font-size: 14px; color: #888; margin-bottom: 28px; max-width: 380px; }
  .suggestions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; max-width: 560px; }
  .suggestion-chip {
    background: #fff; border: 1px solid #e0e8ff; border-radius: 20px;
    padding: 8px 16px; font-size: 13px; font-weight: 500; color: #3b6fd4;
    cursor: pointer; transition: all 0.2s;
  }
  .suggestion-chip:hover { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }

  /* Message bubbles */
  .message-row {
    display: flex; gap: 10px; align-items: flex-start;
    animation: fadeUp 0.25s ease;
  }
  .message-row.user  { flex-direction: row-reverse; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .msg-avatar {
    width: 32px; height: 32px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; flex-shrink: 0; margin-top: 2px;
  }
  .msg-avatar.bot  { background: #1a1a2e; color: #fff; }
  .msg-avatar.user { background: #6c8ebf; color: #fff; }

  .msg-bubble {
    max-width: 72%; padding: 12px 16px;
    border-radius: 14px; font-size: 14px; line-height: 1.65;
  }
  .message-row.user  .msg-bubble { background: #1a1a2e; color: #fff; border-bottom-right-radius: 4px; }
  .message-row.bot   .msg-bubble { background: #fff; color: #333; border-bottom-left-radius: 4px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }

  /* Markdown inside bot bubble */
  .msg-bubble p  { margin: 0 0 8px; }
  .msg-bubble p:last-child { margin: 0; }
  .msg-bubble ul, .msg-bubble ol { margin: 6px 0; padding-left: 20px; }
  .msg-bubble li { margin-bottom: 4px; }
  .msg-bubble strong { font-weight: 700; }
  .msg-bubble code  { background: rgba(0,0,0,0.07); padding: 1px 5px; border-radius: 4px; font-size: 12px; }
  .message-row.user .msg-bubble code { background: rgba(255,255,255,0.15); }

  /* Typing indicator */
  .typing-indicator {
    display: none;
    align-items: center; gap: 10px;
  }
  .typing-indicator.show { display: flex; }
  .typing-dots { display: flex; gap: 4px; }
  .typing-dots span {
    width: 7px; height: 7px; border-radius: 50%; background: #bbb;
    animation: bounce 1.2s infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
  }

  /* Input area */
  .input-area {
    background: #fff;
    border-top: 1px solid #f0f0f0;
    padding: 14px 24px;
    flex-shrink: 0;
    box-shadow: 0 -2px 8px rgba(0,0,0,0.05);
  }
  .input-row {
    display: flex; gap: 10px; align-items: flex-end;
    max-width: 860px; margin: 0 auto;
  }
  .input-row textarea {
    flex: 1; border: 1px solid #e5e7eb; border-radius: 12px;
    padding: 11px 14px; font-size: 14px; resize: none;
    outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    max-height: 120px; line-height: 1.5; font-family: inherit;
  }
  .input-row textarea:focus {
    border-color: #1a1a2e;
    box-shadow: 0 0 0 3px rgba(26,26,46,0.08);
  }
  .btn-send {
    width: 44px; height: 44px; border-radius: 12px;
    background: #1a1a2e; color: #fff; border: none;
    display: flex; align-items: center; justify-content: center;
    font-size: 17px; cursor: pointer; flex-shrink: 0;
    transition: background 0.2s, transform 0.1s;
  }
  .btn-send:hover   { background: #2d2d5e; }
  .btn-send:active  { transform: scale(0.95); }
  .btn-send:disabled { background: #ccc; cursor: not-allowed; }
  .input-hint { font-size: 11px; color: #aaa; text-align: center; margin-top: 6px; }

  /* ── Mobile ── */
  @media (max-width: 767.98px) {
    .chat-page {
      height: calc(100dvh - 56px); /* dvh accounts for browser chrome on mobile */
      margin: 0;                   /* remove the negative desktop margin */
    }
    .chat-header { padding: 10px 14px; }
    .chat-header h5 { font-size: 13.5px; }
    .chat-header p  { font-size: 11px; }
    .bot-avatar     { width: 30px; height: 30px; font-size: 14px; border-radius: 8px; }
    .btn-clear      { padding: 5px 10px; font-size: 12px; }

    .messages-area { padding: 14px; gap: 12px; }
    .msg-bubble     { max-width: 88%; font-size: 13.5px; padding: 10px 13px; }
    .msg-avatar     { width: 28px; height: 28px; font-size: 11px; border-radius: 7px; }

    .input-area { padding: 8px 14px 12px; }
    .input-row  { gap: 8px; }
    .input-row textarea { font-size: 14px; padding: 9px 12px; }
    .btn-send   { width: 40px; height: 40px; font-size: 16px; border-radius: 10px; }
    .input-hint { font-size: 10.5px; }

    .welcome-state { padding: 20px 14px; }
    .welcome-icon  { width: 60px; height: 60px; font-size: 26px; border-radius: 16px; }
    .welcome-state h4 { font-size: 17px; }
    .welcome-state p  { font-size: 13px; }
    .suggestion-chip  { font-size: 12px; padding: 7px 12px; }
  }

  /* Blinking cursor while streaming */
  .message-row.bot.streaming .msg-bubble::after {
    content: "▌";
    display: inline;
    color: #7c3aed;
    animation: blink-cursor 0.7s step-end infinite;
    margin-left: 1px;
  }
  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<div class="chat-page">

  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-left">
      <div class="bot-avatar"><i class="bi bi-robot"></i></div>
      <div>
        <h5>HireHub AI Assistant</h5>
        <p>Career advisor &amp; job matcher</p>
      </div>
    </div>
    <% if (messages.length > 0) { %>
      <form action="/chatbot/history?_method=DELETE" method="POST" style="margin:0;" data-confirm="Clear all chat history?">
        <button type="submit" class="btn-clear">
          <i class="bi bi-trash3"></i> Clear
        </button>
      </form>
    <% } %>
  </div>

  <!-- Messages -->
  <div class="messages-area" id="messagesArea">

    <% if (messages.length === 0) { %>
      <div class="welcome-state" id="welcomeState">
        <div class="welcome-icon"><i class="bi bi-robot"></i></div>
        <h4>Hi, I'm your HireHub Assistant!</h4>
        <p>Ask me about job opportunities, get help writing cover letters, or get career advice.</p>
        <div class="suggestions">
          <div class="suggestion-chip" data-prompt="What jobs are available in Toronto?">
            <i class="bi bi-geo-alt me-1"></i>Jobs in Toronto
          </div>
          <div class="suggestion-chip" data-prompt="What internships are currently available?">
            <i class="bi bi-mortarboard me-1"></i>Show internships
          </div>
          <div class="suggestion-chip" data-prompt="Help me write a cover letter for a software developer role">
            <i class="bi bi-file-earmark-text me-1"></i>Write a cover letter
          </div>
          <div class="suggestion-chip" data-prompt="What remote jobs are available?">
            <i class="bi bi-laptop me-1"></i>Remote jobs
          </div>
          <div class="suggestion-chip" data-prompt="I know JavaScript and React, what jobs match my skills?">
            <i class="bi bi-tools me-1"></i>Match my skills
          </div>
          <div class="suggestion-chip" data-prompt="Give me interview tips for a data analyst role">
            <i class="bi bi-chat-dots me-1"></i>Interview tips
          </div>
        </div>
      </div>
    <% } else { %>
      <% messages.forEach(msg => { %>
        <div class="message-row <%= msg.role === 'user' ? 'user' : 'bot' %>">
          <div class="msg-avatar <%= msg.role === 'user' ? 'user' : 'bot' %>">
            <% if (msg.role === 'user') { %>
              <%= currUser.username[0].toUpperCase() %>
            <% } else { %>
              <i class="bi bi-robot"></i>
            <% } %>
          </div>
          <div class="msg-bubble" <% if (msg.role === 'assistant') { %> data-markdown="true" <% } %>>
            <%- msg.role === 'assistant' ? msg.content : msg.content %>
          </div>
        </div>
      <% }) %>
    <% } %>

    <!-- Typing indicator -->
    <div class="message-row bot typing-indicator" id="typingIndicator">
      <div class="msg-avatar bot"><i class="bi bi-robot"></i></div>
      <div class="msg-bubble" style="padding:14px 18px;">
        <div class="typing-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>

  </div>

  <!-- Input -->
  <div class="input-area">
    <div class="input-row">
      <textarea
        id="chatInput"
        placeholder="Ask about jobs, cover letters, career advice..."
        rows="1"
        autofocus
      ></textarea>
      <button class="btn-send" id="sendBtn" title="Send message">
        <i class="bi bi-send-fill"></i>
      </button>
    </div>
    <p class="input-hint">Press Enter to send &nbsp;·&nbsp; Shift+Enter for new line</p>
  </div>

</div>

<!-- marked.js for markdown rendering -->
<script src="https://cdn.jsdelivr.net/npm/marked@9/marked.min.js"></script>

<script>
  const messagesArea   = document.getElementById("messagesArea");
  const chatInput      = document.getElementById("chatInput");
  const sendBtn        = document.getElementById("sendBtn");
  const typingIndicator = document.getElementById("typingIndicator");
  const welcomeState   = document.getElementById("welcomeState");
  const currentUsername = "<%= currUser.username[0].toUpperCase() %>";

  // Configure marked for safe rendering
  marked.setOptions({ breaks: true, gfm: true });

  // Render any existing assistant messages as markdown
  document.querySelectorAll('.msg-bubble[data-markdown="true"]').forEach(el => {
    el.innerHTML = marked.parse(el.textContent || "");
  });

  // Auto-scroll to bottom on load
  scrollToBottom();

  // Auto-resize textarea
  chatInput.addEventListener("input", () => {
    chatInput.style.height = "auto";
    chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + "px";
  });

  // Send on Enter (Shift+Enter for newline)
  chatInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  sendBtn.addEventListener("click", sendMessage);

  document.querySelectorAll(".suggestion-chip").forEach(chip => {
    chip.addEventListener("click", () => fillPrompt(chip.dataset.prompt));
  });

  function fillPrompt(text) {
    chatInput.value = text;
    chatInput.focus();
    chatInput.dispatchEvent(new Event("input"));
  }

  function scrollToBottom() {
    messagesArea.scrollTop = messagesArea.scrollHeight;
  }

  // Append a fully-formed message bubble (used for user messages and error messages)
  function appendMessage(role, content) {
    if (welcomeState) welcomeState.style.display = "none";

    const row = document.createElement("div");
    row.className = `message-row ${role === "user" ? "user" : "bot"}`;

    const avatar = document.createElement("div");
    avatar.className = `msg-avatar ${role === "user" ? "user" : "bot"}`;
    avatar.innerHTML = role === "user"
      ? currentUsername
      : '<i class="bi bi-robot"></i>';

    const bubble = document.createElement("div");
    bubble.className = "msg-bubble";
    if (role === "assistant") {
      bubble.innerHTML = marked.parse(content);
    } else {
      bubble.textContent = content;
    }

    row.appendChild(avatar);
    row.appendChild(bubble);
    messagesArea.insertBefore(row, typingIndicator);
    scrollToBottom();
  }

  // Create an empty streaming bubble (appears word-by-word)
  function createStreamingBubble() {
    if (welcomeState) welcomeState.style.display = "none";

    const row = document.createElement("div");
    row.className = "message-row bot streaming";

    const avatar = document.createElement("div");
    avatar.className = "msg-avatar bot";
    avatar.innerHTML = '<i class="bi bi-robot"></i>';

    const bubble = document.createElement("div");
    bubble.className = "msg-bubble";

    row.appendChild(avatar);
    row.appendChild(bubble);
    messagesArea.insertBefore(row, typingIndicator);
    scrollToBottom();

    return { row, bubble };
  }

  async function sendMessage() {
    const text = chatInput.value.trim();
    if (!text) return;

    // Show user message immediately
    appendMessage("user", text);
    chatInput.value = "";
    chatInput.style.height = "auto";
    sendBtn.disabled = true;

    // Show typing indicator until first chunk arrives
    typingIndicator.classList.add("show");
    scrollToBottom();

    let streamRow  = null;
    let botBubble  = null;
    let fullText   = "";
    let finished   = false;

    try {
      const res = await fetch("/chatbot/message", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: text }),
      });

      // Non-SSE error response (e.g. validation failure before headers were set)
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        typingIndicator.classList.remove("show");
        appendMessage("assistant", `⚠️ ${data.error || "Something went wrong. Please try again."}`);
        return;
      }

      const reader  = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });

        // SSE events are separated by double newlines
        const events = buffer.split("\n\n");
        buffer = events.pop() ?? ""; // last element may be incomplete

        for (const event of events) {
          const line = event.trim();
          if (!line.startsWith("data: ")) continue;
          const payload = line.slice(6); // strip "data: "

          if (payload === "[DONE]") {
            finished = true;
            // Render full accumulated text as markdown
            if (botBubble) {
              botBubble.innerHTML = marked.parse(fullText);
              streamRow.classList.remove("streaming"); // remove blinking cursor
            }
            scrollToBottom();
            break;
          }

          if (payload === "[ERROR]") {
            finished = true;
            typingIndicator.classList.remove("show");
            if (!botBubble) {
              appendMessage("assistant", "⚠️ Something went wrong. Please try again.");
            } else {
              // Render whatever we got, then stop
              botBubble.innerHTML = marked.parse(fullText || "⚠️ The response was cut short.");
              streamRow.classList.remove("streaming");
            }
            break;
          }

          // Regular chunk
          try {
            const chunk = JSON.parse(payload);
            fullText += chunk;

            // First chunk: swap typing indicator for the streaming bubble
            if (!botBubble) {
              typingIndicator.classList.remove("show");
              const created = createStreamingBubble();
              streamRow = created.row;
              botBubble = created.bubble;
            }

            // Show plain text while streaming (markdown rendered at [DONE])
            botBubble.textContent = fullText;
            scrollToBottom();
          } catch (_) {
            // ignore malformed chunk
          }
        }

        if (finished) break;
      }

      // Safety fallback: render markdown if stream closed without [DONE]
      if (!finished && botBubble) {
        botBubble.innerHTML = marked.parse(fullText);
        streamRow.classList.remove("streaming");
      }

    } catch (err) {
      typingIndicator.classList.remove("show");
      if (!botBubble) {
        appendMessage("assistant", "⚠️ Network error. Please check your connection and try again.");
      } else {
        botBubble.innerHTML = marked.parse(fullText || "⚠️ Connection lost.");
        streamRow && streamRow.classList.remove("streaming");
      }
    } finally {
      sendBtn.disabled = false;
      chatInput.focus();
      scrollToBottom();
    }
  }
</script>
